# =====================================================
# Lunar Rover Console - 環境変数テンプレート
# =====================================================
# このファイルを複製して ".env" にリネームし、
# 自分の環境に合わせた値を入力してください。
#
#   cp .env.example .env
# =====================================================

# --- 通信モード ---
# XBee AT モード (シリアル通信) を使う場合 : main.py の USE_XBEE = True に設定
# Wi-Fi モード (rosbridge WebSocket) を使う場合 : main.py の USE_XBEE = False に設定

# --- XBee 設定 (USE_XBEE = True のときに使用) ---
# Windows の場合: COM3, COM4, ... など
# Ubuntu の場合 : /dev/ttyUSB0 など
XBEE_PORT=COM3
XBEE_BAUD_RATE=115200

# --- Wi-Fi / rosbridge 設定 (USE_XBEE = False のときに使用) ---
ROSBRIDGE_IP=localhost
ROSBRIDGE_PORT=9090

# --- Google Sheets ログ (任意) ---
# Google サービスアカウントの認証情報 (JSON 文字列)
# 不要な場合はこの行をコメントアウトしたままにしてください
# GOOGLE_CREDENTIALS_JSON='{...}'
